// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(cuid())
  name             String
  surname          String         @default("")
  email            String         @unique
  password         String
  plan             String         @default("free")
  stripeCustomerId String?        @unique
  bio              String?
  website          String?
  location         String?
  bios             Bio[]
  subscriptions    Subscription[]
  createdAt        DateTime       @default(now())
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String
  stripeSubscriptionId String?  @unique
  stripeSessionId      String?  @unique
  planId               String
  status               String   @default("pending") // pending, active, cancelled, expired
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now()) @updatedAt
  user                 User     @relation(fields: [userId], references: [id])
}

model Bio {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  style     String   @default("neutro")
  template  String   @default("minimalista")
  links     Json     @default("[]")
  publicUrl String   @unique
  isPublic  Boolean  @default(false)
  views     Int      @default(0)
  avatar    String?  // URL da imagem do avatar
  theme     Json     @default("{\"primaryColor\": \"#3b82f6\", \"backgroundColor\": \"#ffffff\", \"textColor\": \"#1f2937\"}") // Configurações de tema
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  bioViews  BioView[]
}

model BioView {
  id        String   @id @default(cuid())
  bioId     String
  ipAddress String?
  userAgent String?
  referrer  String?
  createdAt DateTime @default(now())
  bio       Bio      @relation(fields: [bioId], references: [id], onDelete: Cascade)
}
